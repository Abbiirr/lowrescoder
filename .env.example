# LLM Gateway (default — OpenAI-compatible, 9 free providers with auto-failover)
# Gateway docs: http://localhost:4001/docs
# Health check: curl http://localhost:4000/health/readiness
AUTOCODE_LLM_PROVIDER=openrouter
AUTOCODE_LLM_API_BASE=http://localhost:4000/v1
OPENROUTER_API_KEY=sk-my-secret-gateway-key
OPENROUTER_MODEL=coding
LITELLM_MASTER_KEY=sk-my-secret-gateway-key

# Direct Ollama (alternative — for local-only inference)
# AUTOCODE_LLM_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3:8b
